+
+NODE _top_pages_0
+SQL >
+
+    %
+    select
+        case when post_uuid = 'undefined' then '' else post_uuid end as post_uuid,
+        pathname,
+        uniqExact(session_id) as visits
+    from _mv_hits h
+    inner join filtered_sessions_v2 fs
+        on fs.session_id = h.session_id
+    where
