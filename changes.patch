+                "context_requests": [],
+            }
+        return {
+            "choices": [{"message": {"content": json.dumps(content)}}],
+            "usage": {"prompt_tokens": 20, "completion_tokens": 8},
+        }
+
+    monkeypatch.setattr(
+        "code_review_agent.review.agents._post_openai_compatible_json",
+        fake_post,
