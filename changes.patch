+### 3.2 API зҖ№еҪ’ж•Ҡж¶“еәЁеҷёз’Ү?+
+**йҗңжү®е§ё**й”ӣжӯҡOpenAICompatibleReviewAgent` иӨ°ж’іеў йҚҷоҒҶж•Ө `urllib.request.urlopen`й”ӣеІғз§ҙйҸғиҲөжӨӮйҺ¶ж¶ңпјҳ `URLError`й”ӣеұҫз—…йҸҲеӨҗеҷёз’ҮжӣҳвӮ¬?+
+**йҸӮжқҝо–ғ `_retry_with_backoff()`**й”ӣе ўеҮҪ stdlibй”ӣеІ„жөӮз»—оғҝз¬ҒйҸӮйҖӣз··з’§ж өзҙҡй”ӣ?+
+```python
+from __future__ import annotations
+
+import time
+from collections.abc import Callable
+from typing import TypeVar
+from urllib import error as urllib_error
+
+T = TypeVar("T")
+
+_RETRYABLE_HTTP_CODES: frozenset[int] = frozenset({429, 500, 502, 503, 504})
+
+
+def _retry_with_backoff(
+    fn: Callable[[], T],
+    *,
+    max_attempts: int = 3,
+    base_delay_seconds: float = 2.0,
+    backoff_factor: float = 2.0,
+    retry_log: list[str] | None = None,
+) -> T:
+    """
+    Retry fn with exponential backoff on transient errors.
+    On fatal errors (401, 400, non-retryable), raises immediately.
+    """
+    last_exc: Exception | None = None
+    for attempt in range(max_attempts):
+        try:
+            return fn()
+        except urllib_error.HTTPError as exc:
+            if exc.code not in _RETRYABLE_HTTP_CODES:
+                # 401 Unauthorized / 403 Forbidden / 400 Bad Request йҲ«?ж¶“е¶үеҷёз’Ү?+                raise _AgentFatalError(f"HTTP {exc.code}: {exc.reason}") from exc
+            last_exc = exc
+            wait = _retry_after(exc) or (base_delay_seconds * (backoff_factor ** attempt))
+            if retry_log is not None:
+                retry_log.append(
+                    f"attempt {attempt + 1} failed: HTTP {exc.code}, retrying in {wait:.1f}s"
+                )
+            time.sleep(wait)
+        except urllib_error.URLError as exc:
+            last_exc = exc
+            wait = base_delay_seconds * (backoff_factor ** attempt)
+            if retry_log is not None:
+                retry_log.append(
+                    f"attempt {attempt + 1} failed: URLError {exc.reason}, retrying in {wait:.1f}s"
+                )
+            time.sleep(wait)
+    raise _AgentTransientError(
+        f"API call failed after {max_attempts} attempts"
+    ) from last_exc
+
+
+def _retry_after(exc: urllib_error.HTTPError) -> float | None:
+    """Parse Retry-After header (seconds or HTTP-date) if present."""
+    header = exc.headers.get("Retry-After") if exc.headers else None
+    if header is None:
+        return None
+    try:
+        return float(header)
+    except ValueError:
+        return None  # HTTP-date йҸҚз…ҺзҙЎйҸҶеӮҷз¬үз‘ҷпҪҶзҖҪй”ӣеІ„вӮ¬вӮ¬йҚҘ?backoff
+```
+
+**й–ҝж¬’оҮӨйҚ’е—ҷиў«ж¶“еәЎоҳ©йҗһе—ҷз“ҘйҗЈ?*й”ӣ?+
+| й–ҝж¬’оҮӨз»«иҜІзҖ· | HTTP йҗ®?/ еҜ®еӮҡзҲ¶ | жҫ¶еӢӯжӮҠ |
+|---|---|---|
+| жқ©зӮҙеёҙз“’е‘®жӨӮ / DNS жҫ¶иҫ«и§Ұ | `urllib.error.URLError` | й–Іе¶ҲзҳҜй”ӣеұҫеҜҡйҸҒдјҙвӮ¬вӮ¬й–¬?|
+| й—„ж„ӯзҘҰ | 429 | й–Іе¶ҲзҳҜй”ӣеұҪзҡ§й–І?`Retry-After` header |
+| йҸҲе¶…е§ҹйҸҶеӮӣжӨӮж¶“е¶…еҪІйҗў?| 500 / 502 / 503 / 504 | й–Іе¶ҲзҳҜ |
+| з’Үй”Ӣзң°йҸҚз…ҺзҙЎй–ҝж¬’оҮӨ | 400 | ж¶“е¶үеҷёз’ҮжӣӘзҙқз’Ғжқҝз¶Қ prompt hashй”ӣеІғиӣӢ Fallback |
+| з’ҒгӮҲзҳүжҫ¶иҫ«и§Ұ | 401 / 403 | ж¶“е¶үеҷёз’ҮжӣӘзҙқз»”е¬ӘеөҶйҺ¶?`_AgentFatalError`й”ӣе Ҙеҷёз’ҮжӣҹжЈӨйҺ°еҝҺз®ҹй”ӣ?|
+| JSON з‘ҷпҪҮзҲңжҫ¶иҫ«и§Ұ | йҲҘ?| ж¶“е¶үеҷёз’ҮжӣӘзҙқз’Ғжқҝз¶ҚйҚҳзҶ·оқҗйҚқе¶…з°Ій”ӣеІғиӣӢ Fallback |
+| Schema жҘ еІғзҳүжҫ¶иҫ«и§Ұй”ӣеқӢvidence_ids ж¶“иҷ№в”–з»ӣеӨӣзҙҡ | йҲҘ?| ж¶“е¶үеҷёз’ҮжӣӘзҙқissue й—„е¶ҮйӘҮж¶“?`needs_human_review` |
+
