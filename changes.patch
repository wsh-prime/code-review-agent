+### 3.7 AgentRun Tracingй”ӣе қеҪІз‘ҷеӮӣзҘҙйҺ¬СҚзҙҡ
+
+**й‘іеұҫж«ҷ**й”ӣжӯ„penAI Agents SDKй”ӣ?5k+ starsй”ӣеӨҠжӢ° LangGraph й–®иҠҘеҰё tracing йҚ’жӨҫиҙҹйҸҚзЁҝзёҫй‘іи—үе§Ҹй”ӣеІ„жҪ°з’Үжӣһз•јйҸ…оҮҖдә¶йҸҲзҶ·з·ҹйҗӘе¬ӘеҹҢ agent з’ӢеҶӘж•ӨйҗЁеӢ«еҪІз‘ҷеӮӣзҘҙйҺ¬СҶоҶ•з’ҒВ°вӮ¬еӮӣеһңжө о„Ӯж®‘ `AgentRun` е®ёиҢ¬зІЎйҸ„?tracing йҗЁеӢҜжҙҖиӨ°оқ®зҙқйҚҷоҒ„жЁҠеҜӨжғ°з№ңйҚң?token з’Ғв„ғжҡҹж¶“гӮ„йҮңзҖӣжҘҒоҶҢйҠҶ?+
+`AgentRun` йҚҰг„ҘеҮЎйҸҲеӨҠз“§еЁҲе…ёз®Јжҫ¶ж ¬жӢ·йҚ”зӢ…зҙ°
+
+```python
+@dataclass(slots=True)
+class AgentRun:
+    # ... е®ёеҸүж№ҒзҖӣжҘҒоҶҢй”ӣеқ•teration / retry_count / retry_log / feedback_hashй”ӣ?..
+    # --- Tracing йҸӮжқҝо–ғзҖӣжҘҒоҶҢ ---
+    latency_ms: int = 0                    # йҸҲо„ҒоӮјз’ӢеҶӘж•Өжҫ§ж¬“жҢ“йҸғе •жЈҝй”ӣеқўsй”ӣ?+    token_count_in: int = 0                # prompt token йҸҒеё®зҙҷжө еәЎжҗ·жҗҙ?usage з’ҮиҜІеҪҮй”ӣ?+    token_count_out: int = 0               # completion token йҸҒ?+    cache_hit: bool = False                # йҸ„оҲҡжғҒйҚӣжҲ’и…‘ prompt cacheй”ӣе ЈоқҶ 3.8 й‘әеӮҰзҙҡ
+    cache_saved_tokens: int = 0            # йҚҘ?cache й‘әеӮңжё·йҗЁ?token йҸҒ?+```
+
+`latency_ms` йҚҰ?`_retry_with_backoff` йҗЁеӢ®зҡҹйҗўг„Өжҷ¶й–Іеӣ¬жіҰй”ӣ?+
+```python
+import time
+
+start = time.monotonic()
+try:
+    response = _retry_with_backoff(fn, retry_log=run.retry_log)
+finally:
+    run.latency_ms = int((time.monotonic() - start) * 1000)
+```
+
+`token_count_in / token_count_out` жө ?OpenAI-compatible йҚқе¶…з°ІйҗЁ?`usage` зҖӣжҘҒоҶҢз’ҮиҜІеҪҮй”ӣе қеҮЎйҚҰг„Ҙжҗ·жҗҙ?JSON ж¶“о…ЁзҙқйҸғзҠ»жё¶жЈ°жҝҶоҳ»з’ӢеҶӘж•Өй”ӣеӨӣзҙ°
+
+```python
+usage = response.get("usage", {})
+run.token_count_in = usage.get("prompt_tokens", 0)
+run.token_count_out = usage.get("completion_tokens", 0)
+# prompt_cache_hit_tokens йҸ„?Anthropic йҺөв•ҒзқҚзҖӣжҘҒоҶҢй”ӣе ЈоқҶ 3.8 й‘әеӮҰзҙҡ
+run.cache_saved_tokens = usage.get("prompt_cache_hit_tokens", 0)
+run.cache_hit = run.cache_saved_tokens > 0
+```
+
+**Tracing йҚҰг„Ұе§ӨйҚӣе©Ғи…‘йҗЁеӢ«жҶҹйҗң?*й”ӣжӯҡreview_report.json` йҗЁ?`agent_runs` йҸҒжү®зІҚе®ёеҸүж№Ғе§Јеҝ”оӮјз’ӢеҶӘж•Өз’Ғжқҝз¶Қй”ӣе®ӯoop зјҒж’ҙжҪ«йҚҡеәӨжӢ·йҚ”зҠәд»ӣйҚҡе ҹжҶіз‘•дҪёеҹҢ `tracing` зҖӣжҘҒоҶҢй”ӣ?+
+```json
+"tracing": {
+  "total_latency_ms": 4821,
+  "total_token_in": 3200,
+  "total_token_out": 480,
+  "total_cache_saved_tokens": 1800,
+  "per_run": [
+    {"agent_name": "openai_compatible_reviewer", "iteration": 0,
+     "latency_ms": 2341, "token_in": 1800, "token_out": 280,
+     "cache_hit": false, "cache_saved_tokens": 0},
+    {"agent_name": "openai_compatible_reviewer", "iteration": 1,
+     "latency_ms": 2480, "token_in": 1400, "token_out": 200,
+     "cache_hit": true, "cache_saved_tokens": 1800}
+  ]
+}
+```
+
+**ж¶“иҪ°зІҲж¶”е қоҮ®й—ҲгҲЈзҳҜйҸҲеӨүзҺҜйҚҠ?*й”ӣж°¶жҪ°з’Үжӣһз•јйҗӘе¬ӘеҹҢ tracing жөјж°ұжҙҝйҺәгғ©жЈ¶"жөЈзҠівӮ¬еәқз®һйҗӯгғ©дәҫйҚқоҒғз«ҙжқһоҶҪеҸғйҠҶдҪёж‘ўж¶“вӮ¬жқһ?token жҫ¶ж°ҫзҙө"йҠҶеӮӣж№Ғ `latency_ms` йҚң?`token_count` зҒҸиҫ«е…ҳйҚҘзӮөз“ҹй”ӣеұҫз—…йҸҲеӨҠж°ЁйҸ„оҲһзІҰйҗ©жҺӢвӮ¬еӮҷз¬–жқ©ж¬Һз°әзҖӣжҘҒоҶҢйҚҰ?eval ж¶“о…һеҪІжө гғ§жҙҝйҺәгғҘоҮ®е§Ј?loop=1 vs loop=2 йҗЁеӢ¬вӮ¬?token еҜ®вӮ¬й–ҝвӮ¬"й”ӣеІҖзІ° tradeoff йҚ’е—ҳзҖҪйҺ»ж„Әз·өйҸҒжқҝз“§жёҡжҝҮеөҒйҠҶ?+
