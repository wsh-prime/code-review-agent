+
+йҸҮеӯҳжҹҠйҚҡеәЈж®‘ Protocolй”ӣ?+
+```python
+# review/agents.py
+class ReviewAgent(Protocol):
+    def review(
+        self,
+        package: EvidencePackage,
+        *,
+        prior_feedback: PriorFeedback | None = None,
