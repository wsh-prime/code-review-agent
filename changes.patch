+### 3.4 йӘһеӮңз“‘йҺ¬СӮз¬Ң AgentRun жқ©еҖҹйҮң
+
+**йҗ©оҶҪзҲЈ**й”ӣж°іоҶҖе§Јеҝ”оӮј agent з’ӢеҶӘж•ӨйҚҰ?`AgentRun` ж¶“о… жҡҖж¶“е¬ӘеҪІжқ©еҖҹйҮңйҗЁеӢ®з·ӯйҚҸгғҰеҜҡз»ҫзҷёзҙқйҸҖоҲӣеҜ” eval йҚҘзӮІз¶ҠйҚң?debugйҠҶ?+
+`AgentRun` йҸӮжқҝо–ғзҖӣжҘҒоҶҢй”ӣеқ„models.py`й”ӣеӨӣзҙ°
+
+```python
+@dataclass(slots=True)
+class AgentRun:
+    # --- йҗңзүҲж№ҒзҖӣжҘҒоҶҢ ---
+    agent_name: str
+    model: str
+    prompt_hash: str
+    input_evidence_ids: list[str]
+    output_issue_ids: list[str]
+    fallback_used: bool
+    # --- йҸӮжқҝо–ғзҖӣжҘҒоҶҢ ---
+    iteration: int = 0                    # йҺөвӮ¬зҒһ?loop жқһоҶҪоӮјй”ӣе қеҙҹеЁҶ?pass йҸғ?= 0й”ӣ?+    feedback_hash: str = ""               # PriorFeedback JSON йҗЁ?sha256й”ӣе ҹжЈӨ feedback йҸғ?= ""й”ӣ?+    retry_count: int = 0                  # зҖ№зӮәжӘҜйҚҷжҲ ж•“йҗЁеӢҜеҷёз’ҮжӣҹоӮјйҸҒ?+    retry_log: list[str] = field(default_factory=list)  # е§Јеҝ”оӮјй–Іе¶ҲзҳҜйҚҳзҶ·жҙң
+```
+
+**жқҲж’іеҸҶйҺёеӣ©жұ—ж¶“еӨҠеҺ“зјҒ?*й”ӣ?+
+```
+prompt_hash + feedback_hash + sorted(input_evidence_ids)
+```
+
+й‘»гғӨиўұеЁҶВӨз№ҚзҗӣеІҖж®‘ж¶“еӨҠеҺ“зјҒеӢӯжөүйҚҡеІӢзҙ°
+- **fake agent**й”ӣж°із·ӯйҚ‘е“„з•¬йҚҸг„§вҖҳзҖ№ж°ҫзҙқeval йӘһеӮңз“‘й”ӣеӯӢI ж¶“?flakyйҠҶ?+- **live agent**й”ӣеқ„temperature=0`й”ӣеӨӣзҙ°жқҲж’іеҡӯжҫ¶С„оӣ§йҗңеӣ©жөүйҚҡеІӢзҙқйҚҷоҲңж•Өжөң?diff з’ӢеҶӯзҳҜйҠҶ?+
+`feedback_hash` йҗЁеӢ®о…ёз» жҘӢзҙ°
+
+```python
+def _feedback_hash(feedback: PriorFeedback | None) -> str:
+    if feedback is None:
+        return ""
+    raw = json.dumps(
+        {
+            "iteration": feedback.iteration,
+            "uncertain_items": [
+                {"issue_id": item.issue_id, "critic_reason": item.critic_reason}
+                for item in feedback.uncertain_items
+            ],
+        },
+        sort_keys=True,
+        ensure_ascii=False,
+    )
+    return "sha256:" + hashlib.sha256(raw.encode()).hexdigest()[:16]
+```
